# =============================================================================
# ThreatDex — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Supabase (required)
# Create a project at https://supabase.com and copy these from Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...          # Public key — safe to use in browser
SUPABASE_SERVICE_KEY=eyJ...       # Private key — server-side only (workers + loaders)

# CTI sources (optional — workers skip gracefully if missing)
# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=

# Image generation uses Stable Horde (free volunteer GPU network, no key required)
# Optional: register at stablehorde.net for higher priority queue
STABLE_HORDE_API_KEY=

# Future optional connectors (not part of initial rewrite)
MISP_URL=
MISP_API_KEY=
OPENCTI_URL=
OPENCTI_API_KEY=
