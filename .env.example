# =============================================================================
# ThreatDex — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# Admin secret for protected API endpoints (POST /api/admin/sync/*)
ADMIN_SECRET=your-admin-secret-here

# -----------------------------------------------------------------------------
# Infrastructure (required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://threatdex:threatdex@localhost:5432/threatdex

# Redis connection string (used by Celery workers and API cache)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=8000

# Public URL of the API server — consumed by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# CTI Sources — optional
# If a key is missing the corresponding connector is skipped gracefully.
# -----------------------------------------------------------------------------

# AlienVault OTX (https://otx.alienvault.com/api)
# Create a free account and generate an API key from your profile settings.
OTX_API_KEY=

# SOCRadar (optional enrichment)
SOCRADAR_API_KEY=

# OpenAI — used by the image generation worker (workers/image-gen)
OPENAI_API_KEY=

# MISP (optional, self-hosted)
# Point MISP_URL at your own MISP instance.
MISP_URL=
MISP_API_KEY=

# OpenCTI (optional, self-hosted)
# Point OPENCTI_URL at your own OpenCTI instance.
OPENCTI_URL=
OPENCTI_API_KEY=
