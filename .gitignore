# =============================================================================
# ThreatDex — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment files — never commit secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
# .env.example is intentionally NOT ignored — it is committed as a template

# -----------------------------------------------------------------------------
# Node.js / JavaScript / TypeScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build outputs
dist/
build/
out/

# Type declaration caches
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
.next/cache/
next-env.d.ts

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.whl
.installed.cfg
MANIFEST

# Virtual environments
venv/
.venv/
ENV/
env/
.env/

# pip
pip-log.txt
pip-delete-this-directory.txt

# pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
nosetests.xml

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff cache
.ruff_cache/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Ignore local docker override files that may contain secrets
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
tmp/
temp/
*.tmp
*.bak
*.orig
