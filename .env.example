# =============================================================================
# ThreatDex — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Supabase (required)
# Create a project at https://supabase.com and copy these from Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...          # Public key — safe to use in browser
SUPABASE_SERVICE_KEY=eyJ...       # Private key — server-side only (workers + loaders)

# CTI sources (optional — workers skip gracefully if missing)
# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=

# Image generation (optional — pick one or more)
# Google Gemini Imagen 3 (recommended, ~$0.04/image)
GEMINI_API_KEY=
# Hugging Face Inference (free tier available)
HF_API_KEY=
# Stable Horde (free, community-powered)
STABLE_HORDE_API_KEY=
# OpenAI DALL-E (legacy)
OPENAI_API_KEY=

# Future optional connectors (not part of initial rewrite)
MISP_URL=
MISP_API_KEY=
OPENCTI_URL=
OPENCTI_API_KEY=
