{
  "name": "threatdex",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Know your adversaries, card by card.",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app workers --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "workers:mitre": "node --env-file=.env --import tsx workers/mitre-sync.ts",
    "workers:etda": "node --env-file=.env --import tsx workers/etda-sync.ts",
    "workers:otx": "node --env-file=.env --import tsx workers/otx-sync.ts",
    "workers:image": "node --env-file=.env --import tsx workers/image-gen.ts",
    "workers:all": "npm run workers:mitre && npm run workers:etda && npm run workers:otx"
  },
  "dependencies": {
    "@react-router/node": "^7.0.0",
    "@react-router/serve": "^7.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "clsx": "^2.1.0",
    "html2canvas": "^1.4.1",
    "isbot": "^4.4.0",
    "lucide-react": "^0.316.0",
    "openai": "^4.26.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@netlify/vite-plugin-react-router": "^3.1.1",
    "@playwright/test": "^1.42.0",
    "@react-router/dev": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.2.1",
    "cheerio": "^1.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.11",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
